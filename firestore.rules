rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
         (request.auth.token.email == "salvomontevago@gmail.com" && request.auth.token.email_verified == true));
    }

    // Check if it's a rooms collection
    function isRoomsCollection(col) {
      return col == 'rooms' || 
             col == 'checkers_rooms' || 
             col == 'chess_rooms' || 
             col == 'tictactoe_rooms' ||
             col == 'connect4_rooms' ||
             col == 'clashboo_rooms';
    }

    match /{col}/{roomCode} {
      allow read: if isAuthenticated() && isRoomsCollection(col);
      
      allow create: if isAuthenticated() 
        && isRoomsCollection(col)
        && (request.resource.data.p1.id == request.auth.uid);
        
      allow update: if isAuthenticated()
        && isRoomsCollection(col)
        && (
          // Guest joining: allow if status is WAITING and p2 is being set
          (resource.data.status == 'WAITING') ||
          // Existing players updating: allow if user is p1 or p2
          (request.auth.uid == resource.data.p1.id || 
           (resource.data.p2 != null && request.auth.uid == resource.data.p2.id))
        );
        
      allow delete: if isAuthenticated() 
        && isRoomsCollection(col)
        && (resource.data.p1.id == request.auth.uid);
    }

    // User profiles
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow write: if isOwner(userId) || isAdmin();
    }
  }
}
